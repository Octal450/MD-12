<PropertyList include="MD-12-main.xml">
	
    <sim>
		<aero>FDE/MD-12</aero>
		<description>McDonnell Douglas MD-12 (Fictional, CF6-80C2D1F)</description>
		<flight-model>jsb</flight-model>
		<model n="0">
			<livery>
				<file type="string">White</file>
			</livery>
			<path>Aircraft/MD-12/Models/MD-12.xml</path>
		</model>
		<sound n="0">
			<path>Aircraft/MD-12/Sounds/cf680-sound.xml</path>
		</sound>
		<systems n="0">
			<autopilot n="6">
				<path>Aircraft/MD-12/Sounds/cf680-sound-control.xml</path>
			</autopilot>
		</systems>
    </sim>
	
	<limits>
		<mass-and-balance>
			<maximum-landing-mass-lbs>680000</maximum-landing-mass-lbs>
			<maximum-takeoff-mass-lbs>1022000</maximum-takeoff-mass-lbs>
			<maximum-zero-fuel-mass-lbs>640000</maximum-zero-fuel-mass-lbs>
		</mass-and-balance>
	</limits>
	
	<nasal n="0">
		<setup>
			<script>aircraft.livery.init("Aircraft/MD-12/Models/Liveries");</script>
		</setup>
	</nasal>

</PropertyList>
